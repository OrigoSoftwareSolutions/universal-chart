        "unhealthyPodEvictionPolicy": {
          "type": "string",
          "enum": [
            "IfHealthyBudget",
            "AlwaysAllow"
          ]
        },
        "extraSelectorLabels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "pvc": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "accessModes": {
          "type": "array"
        },
        "size": {
          "type": "string"
        },
        "storageClassName": {
          "type": "string"
        },
        "volumeMode": {
          "type": "string",
