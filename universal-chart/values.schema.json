{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "universal-chart values",
  "description": "Schema for Origo universal-chart values validation",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "releasePrefix": {
      "type": "string",
      "description": "Prefix prepended to all resource names. Leave empty to disable."
    },
    "defaultImage": {
      "type": "string",
      "description": "Fallback container image used when a workload omits image."
    },
    "defaultImageTag": {
      "type": ["string", "number"],
      "description": "Fallback container image tag. Always quote numeric tags."
    },
    "defaultImagePullPolicy": {
      "$ref": "#/$defs/imagePullPolicy"
    },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Image pull secret names referenced in every pod spec."
    },
    "diagnosticMode": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "description": "Default settings applied to all workload templates.",
      "properties": {
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "hookAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "extraSelectorLabels": { "type": "object", "additionalProperties": { "type": "string" } },
        "podLabels": { "type": "object", "additionalProperties": { "type": "string" } },
        "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "extraImagePullSecrets": { "type": "array", "items": { "type": "string" } },
        "usePredefinedAffinity": { "type": "boolean" },
        "serviceAccountName": { "type": "string" },
        "hostAliases": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "priorityClassName": { "type": "string" },
        "dnsPolicy": {
          "type": "string",
          "enum": ["ClusterFirst", "Default", "ClusterFirstWithHostNet", "None"]
        },
        "tolerations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
        "volumes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "volumeMounts": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "resources": { "$ref": "#/$defs/resources" },
        "podSecurityContext": { "$ref": "#/$defs/podSecurityContext" },
        "containerSecurityContext": { "$ref": "#/$defs/containerSecurityContext" },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
        "preStopSleep": { "type": "integer", "minimum": 0 },
        "topologySpreadConstraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/topologySpreadConstraint" }
        }
      }
    },
    "podAffinityPreset": {
      "type": "string",
      "enum": ["soft", "hard", ""],
      "description": "Pod affinity preset"
    },
    "podAntiAffinityPreset": {
      "type": "string",
      "enum": ["soft", "hard", ""],
      "description": "Pod anti-affinity preset"
    },
    "nodeAffinityPreset": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["soft", "hard", ""]
        },
        "key": { "type": "string" },
        "values": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "envs": { "type": "object", "additionalProperties": true },
    "secretEnvs": { "type": "object", "additionalProperties": true },
    "envsString": { "type": "string" },
    "secretEnvsString": { "type": "string" },
    "deployments": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "deploymentsGeneral": { "$ref": "#/$defs/workloadGeneral" },
    "statefulSets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "statefulSetsGeneral": { "$ref": "#/$defs/workloadGeneral" },
    "daemonSets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "daemonSetsGeneral": { "$ref": "#/$defs/workloadGeneral" },
    "cronJobs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/cronJob" }
    },
    "cronJobsGeneral": { "$ref": "#/$defs/workloadGeneral" },
    "jobs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/job" }
    },
    "jobsGeneral": { "$ref": "#/$defs/workloadGeneral" },
    "hooks": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "hooksGeneral": { "$ref": "#/$defs/workloadGeneral" },
    "services": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/service" }
    },
    "configMaps": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "pvcs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/pvc" }
    },
    "hpas": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/hpa" }
    },
    "pdbs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/pdb" }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true
    },
    "serviceAccountGeneral": {
      "type": "object",
      "additionalProperties": true
    },
    "externalSecrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "secretStores": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "clusterSecretStores": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "clusterExternalSecrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "certificates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "issuers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "clusterIssuers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "httpRoutes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istiovirtualservices": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istiogateways": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istiodestinationrules": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istioPeerAuthentications": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istioAuthorizationPolicies": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "serviceMonitors": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "imageUpdaters": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/imageUpdater" }
    },
    "extraDeploy": {
      "type": "object",
      "additionalProperties": {},
      "description": "Raw Kubernetes manifests keyed by name. Values support Helm template expressions."
    }
  },
  "$defs": {
    "disableable": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disabled": { "type": "boolean" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "description": "Kubernetes Service instance.",
      "properties": {
        "disabled": { "type": "boolean" },
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"],
          "description": "Service type."
        },
        "externalTrafficPolicy": {
          "type": "string",
          "enum": ["Cluster", "Local"],
          "description": "External traffic policy for NodePort/LoadBalancer services."
        },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "cronJob": {
      "allOf": [
        { "$ref": "#/$defs/workload" },
        {
          "if": {
            "not": { "properties": { "disabled": { "const": true } }, "required": ["disabled"] }
          },
          "then": {
            "required": ["schedule"]
          }
        }
      ],
      "properties": {
        "schedule": { "type": "string", "description": "Cron schedule expression (required)." },
        "startingDeadlineSeconds": { "type": "integer", "minimum": 0, "description": "Deadline in seconds for starting the job if it misses its scheduled time." },
        "successfulJobsHistoryLimit": { "type": "integer", "minimum": 0, "description": "Number of successful finished jobs to retain." },
        "failedJobsHistoryLimit": { "type": "integer", "minimum": 0, "description": "Number of failed finished jobs to retain." },
        "singleOnly": { "type": "boolean", "description": "Shorthand for concurrencyPolicy: Forbid." },
        "suspend": { "type": "boolean", "description": "Suspend the CronJob." },
        "commandDurationAlert": { "type": "integer", "minimum": 0, "description": "Seconds threshold — creates a PrometheusRule that fires when CronJob execution exceeds this duration." }
      }
    },
    "job": {
      "allOf": [
        { "$ref": "#/$defs/workload" }
      ],
      "properties": {
        "commandDurationAlert": { "type": "integer", "minimum": 0, "description": "Seconds threshold — creates a PrometheusRule that fires when Job execution exceeds this duration." }
      }
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"],
      "description": "Image pull policy."
    },
    "resources": {
      "type": "object",
      "description": "Container resource requests/limits. Must be an object with requests and/or limits.",
      "additionalProperties": true,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": ["string", "number"] },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": ["string", "number"] },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "description": "Pod-level security context.",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer" },
        "runAsGroup": { "type": "integer" },
        "fsGroup": { "type": "integer" },
        "fsGroupChangePolicy": {
          "type": "string",
          "enum": ["Always", "OnRootMismatch"]
        },
        "seccompProfile": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["RuntimeDefault", "Localhost", "Unconfined"]
            }
          }
        },
        "supplementalGroups": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "sysctls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "description": "Container-level security context.",
      "properties": {
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer" },
        "runAsGroup": { "type": "integer" },
        "privileged": { "type": "boolean" },
        "capabilities": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "add": {
              "type": "array",
              "items": { "type": "string" }
            },
            "drop": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "seccompProfile": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["RuntimeDefault", "Localhost", "Unconfined"]
            }
          }
        }
      }
    },
    "topologySpreadConstraint": {
      "type": "object",
      "additionalProperties": true,
      "description": "Topology spread constraint for pod scheduling.",
      "properties": {
        "maxSkew": { "type": "integer", "minimum": 1 },
        "topologyKey": { "type": "string" },
        "whenUnsatisfiable": {
          "type": "string",
          "enum": ["DoNotSchedule", "ScheduleAnyway"]
        },
        "labelSelector": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "healthCheck": {
      "type": "object",
      "additionalProperties": true,
      "description": "Health check shorthand — generates liveness, readiness, and startup probes.",
      "properties": {
        "path": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "scheme": {
          "type": "string",
          "enum": ["HTTP", "HTTPS"]
        },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    },
    "container": {
      "type": "object",
      "additionalProperties": true,
      "description": "Container definition used in the containers list.",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "imageTag": { "type": ["string", "number"] },
        "imagePullPolicy": { "$ref": "#/$defs/imagePullPolicy" },
        "command": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "args": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" },
              "containerPort": { "type": "integer" },
              "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] }
            }
          }
        },
        "resources": { "$ref": "#/$defs/resources" },
        "securityContext": { "$ref": "#/$defs/containerSecurityContext" },
        "envs": { "type": "object" },
        "envsFrom": { "type": "object" },
        "volumeMounts": { "type": "array" },
        "livenessProbe": { "type": "object", "additionalProperties": true },
        "readinessProbe": { "type": "object", "additionalProperties": true },
        "startupProbe": { "type": "object", "additionalProperties": true },
        "lifecycle": { "type": "object", "additionalProperties": true }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": true,
      "description": "Workload instance (Deployment, StatefulSet, DaemonSet, CronJob, Job, Hook).",
      "if": {
        "not": { "properties": { "disabled": { "const": true } }, "required": ["disabled"] }
      },
      "then": {
        "anyOf": [
          { "required": ["image"] },
          { "required": ["containers"] }
        ]
      },
      "properties": {
        "disabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "image": { "type": "string" },
        "imageTag": { "type": ["string", "number"] },
        "imagePullPolicy": { "$ref": "#/$defs/imagePullPolicy" },
        "ports": {
          "description": "Single-container shorthand: map of name→port. Creates containerPorts and a Service.",
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "resources": { "$ref": "#/$defs/resources" },
        "healthCheck": { "$ref": "#/$defs/healthCheck" },
        "podSecurityContext": { "$ref": "#/$defs/podSecurityContext" },
        "securityContext": {
          "$ref": "#/$defs/podSecurityContext",
          "description": "Deprecated alias for podSecurityContext. Prefer podSecurityContext for pod-level settings."
        },
        "containerSecurityContext": { "$ref": "#/$defs/containerSecurityContext" },
        "topologySpreadConstraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/topologySpreadConstraint" }
        },
        "containers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/container" }
        },
        "initContainers": {
          "type": "array",
          "items": { "$ref": "#/$defs/container" }
        },
        "command": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "args": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "serviceAccountName": { "type": "string" },
        "usePredefinedAffinity": { "type": "boolean" },
        "affinity": { "type": "object", "additionalProperties": true, "description": "Custom pod affinity/anti-affinity rules. Overrides predefined affinity." },
        "hostAliases": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "priorityClassName": { "type": "string" },
        "dnsPolicy": { "type": "string", "description": "DNS policy for pods. Supports template expressions." },
        "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
        "tolerations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
        "parallelism": { "type": "integer", "minimum": 0, "description": "Number of pods running at the same time (Jobs/Hooks)." },
        "completions": { "type": "integer", "minimum": 0, "description": "Number of successful completions required (Jobs/Hooks)." },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 0, "description": "Maximum duration in seconds before the Job is terminated." },
        "backoffLimit": { "type": "integer", "minimum": 0, "description": "Number of retries before marking a Job as failed." },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0, "description": "TTL for cleaning up finished Jobs." },
        "progressDeadlineSeconds": { "type": "integer", "minimum": 0, "description": "Maximum time for a Deployment to make progress before considered failed." },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "podLabels": { "type": "object", "additionalProperties": { "type": "string" } },
        "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "service": {
          "description": "Service override. Set false to suppress auto-service, or an object to customize.",
          "oneOf": [
            { "type": "boolean" },
            { "type": "object", "additionalProperties": true }
          ]
        },
        "serviceName": {
          "type": "string",
          "description": "Governing service name for StatefulSets. Defaults to the workload key name."
        },
        "imagePullSecrets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Deprecated: use extraImagePullSecrets instead. Image pull secret names for this workload."
        },
        "extraImagePullSecrets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Additional image pull secrets for this workload, merged with top-level and defaults."
        }
      }
    },
    "workloadGeneral": {
      "type": "object",
      "additionalProperties": true,
      "description": "Shared defaults for a workload kind (*General). Merged with per-instance values.",
      "properties": {
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "podLabels": { "type": "object", "additionalProperties": { "type": "string" } },
        "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "resources": { "$ref": "#/$defs/resources" },
        "podSecurityContext": { "$ref": "#/$defs/podSecurityContext" },
        "securityContext": {
          "$ref": "#/$defs/podSecurityContext",
          "description": "Deprecated alias for podSecurityContext. Prefer podSecurityContext for pod-level settings."
        },
        "containerSecurityContext": { "$ref": "#/$defs/containerSecurityContext" },
        "topologySpreadConstraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/topologySpreadConstraint" }
        },
        "usePredefinedAffinity": { "type": "boolean" },
        "affinity": { "type": "object", "additionalProperties": true, "description": "Custom pod affinity/anti-affinity rules. Overrides predefined affinity." },
        "serviceAccountName": { "type": "string" },
        "hostAliases": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "priorityClassName": { "type": "string" },
        "dnsPolicy": { "type": "string", "description": "DNS policy for pods. Supports template expressions." },
        "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
        "tolerations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
        "parallelism": { "type": "integer", "minimum": 0 },
        "completions": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 0 },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "progressDeadlineSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "pvc": {
      "type": "object",
      "additionalProperties": true,
      "description": "PersistentVolumeClaim instance. Set mountPath to auto-mount into workload containers.",
      "properties": {
        "disabled": { "type": "boolean" },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"]
          }
        },
        "size": { "type": "string", "description": "Storage size (default: 1Gi)." },
        "storageClassName": { "type": "string" },
        "volumeMode": {
          "type": "string",
          "enum": ["Filesystem", "Block"]
        },
        "volumeName": { "type": "string" },
        "mountPath": { "type": "string", "description": "Auto-mount path in workload containers. Omit to skip auto-mounting." },
        "subPath": { "type": "string", "description": "Sub-path within the volume to mount." },
        "readOnly": { "type": "boolean", "description": "Mount the volume read-only." }
      }
    },
    "hpa": {
      "type": "object",
      "additionalProperties": true,
      "description": "HorizontalPodAutoscaler instance.",
      "properties": {
        "disabled": { "type": "boolean" },
        "scaleTargetRef": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string", "enum": ["Deployment", "StatefulSet", "DaemonSet"] }
          }
        },
        "minReplicas": { "type": "integer", "minimum": 0 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPU": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemory": { "type": "integer", "minimum": 1, "maximum": 100 }
      },
      "if": {
        "not": { "properties": { "disabled": { "const": true } }, "required": ["disabled"] }
      },
      "then": {
        "required": ["scaleTargetRef", "minReplicas", "maxReplicas"]
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": true,
      "description": "PodDisruptionBudget instance.",
      "properties": {
        "disabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^(\\d+%|\\d+)$" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^(\\d+%|\\d+)$" }
          ]
        },
        "unhealthyPodEvictionPolicy": {
          "type": "string",
          "enum": ["IfHealthyBudget", "AlwaysAllow"]
        },
        "extraSelectorLabels": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "if": {
        "not": { "properties": { "disabled": { "const": true } }, "required": ["disabled"] }
      },
      "then": {
        "anyOf": [
          {
            "required": ["minAvailable"],
            "not": { "required": ["maxUnavailable"] }
          },
          {
            "required": ["maxUnavailable"],
            "not": { "required": ["minAvailable"] }
          }
        ]
      }
    },
    "envEntry": {
      "type": "object",
      "description": "Individual environment variable with support for valueFrom.",
      "properties": {
        "name": { "type": "string" },
        "value": { "type": ["string", "number", "boolean"] },
        "valueFrom": {
          "type": "object",
          "properties": {
            "configMapKeyRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "key": { "type": "string" },
                "optional": { "type": "boolean" }
              },
              "required": ["name", "key"]
            },
            "secretKeyRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "key": { "type": "string" },
                "optional": { "type": "boolean" }
              },
              "required": ["name", "key"]
            },
            "resourceFieldRef": {
              "type": "object",
              "properties": {
                "containerName": { "type": "string" },
                "resource": { "type": "string" },
                "divisor": { "type": ["string", "number"] }
              },
              "required": ["resource"]
            },
            "fieldRef": {
              "type": "object",
              "properties": {
                "apiVersion": { "type": "string" },
                "fieldPath": { "type": "string" }
              },
              "required": ["fieldPath"]
            }
          }
        }
      },
      "required": ["name"]
    },
    "envMap": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "envFromConfigmap": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "keys": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } },
            {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          ]
        }
      },
      "required": ["name"]
    },
    "envFromSecret": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "keys": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } },
            {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          ]
        }
      },
      "required": ["name"]
    },
    "envConfigmaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/envFromConfigmap" }
    },
    "envSecrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/envFromSecret" }
    },
    "imageUpdater": {
      "type": "object",
      "additionalProperties": true,
      "description": "Argo CD Image Updater instance.",
      "properties": {
        "disabled": { "type": "boolean" },
        "applicationName": { "type": "string", "description": "Argo CD Application name to target." },
        "namespace": { "type": "string", "description": "Namespace where the Argo CD Application lives (default: argocd)." },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "alias": { "type": "string" },
              "imageName": { "type": "string" },
              "updateStrategy": { "type": "string", "enum": ["latest", "newest-build", "alphabetical", "digest"] },
              "allowTags": { "type": "string" },
              "ignoreTags": { "type": "array", "items": { "type": "string" } },
              "manifestTargets": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
            },
            "required": ["alias", "imageName"]
          }
        },
        "writeBackConfig": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "method": { "type": "string" }
          }
        }
      },
      "if": {
        "not": { "properties": { "disabled": { "const": true } }, "required": ["disabled"] }
      },
      "then": {
        "required": ["applicationName", "images"]
      }
    }
  }
}
