{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "universal-chart values",
  "description": "Schema for Origo universal-chart values validation",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "releasePrefix": {
      "type": "string",
      "description": "Prefix prepended to all resource names. Leave empty to disable."
    },
    "podAffinityPreset": {
      "type": "string",
      "enum": ["soft", "hard", ""],
      "description": "Pod affinity preset"
    },
    "podAntiAffinityPreset": {
      "type": "string",
      "enum": ["soft", "hard", ""],
      "description": "Pod anti-affinity preset"
    },
    "nodeAffinityPreset": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["soft", "hard", ""]
        },
        "key": { "type": "string" },
        "values": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "envs": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "secretEnvs": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "envsString": { "type": "string" },
    "secretEnvsString": { "type": "string" },
    "deployments": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "statefulSets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "daemonSets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/workload" }
    },
    "daemonSetsGeneral": {
      "type": "object",
      "additionalProperties": true
    },
    "cronJobs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "jobs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "services": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "configMaps": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "pvcs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "hpas": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "pdbs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "externalSecrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "secretStores": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "clusterSecretStores": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "clusterExternalSecrets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "certificates": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "issuers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "clusterIssuers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "httpRoutes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istiovirtualservices": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istiogateways": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istiodestinationrules": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istioPeerAuthentications": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "istioAuthorizationPolicies": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "serviceMonitors": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/disableable" }
    },
    "extraDeploy": {
      "type": "object",
      "additionalProperties": {},
      "description": "Raw Kubernetes manifests keyed by name. Values support Helm template expressions."
    }
  },
  "$defs": {
    "disableable": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disabled": { "type": "boolean" }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "disabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
